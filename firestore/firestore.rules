rules_version = '2';

// Connect Me — per-contact memory rules.
//
// Memory documents live at:
//   users/{uid}/memories/{contactId}
//
// A memory document is a single Firestore document with three fields:
//   - markdown:      string, <= 64 KiB (65536 bytes)
//   - updatedAt:     timestamp
//   - schemaVersion: int
//
// Rules enforce two things in lock-step:
//
// 1. Ownership. Only the signed-in user whose UID matches the path can
//    read, list, create, update, or delete documents under their own
//    `users/{uid}/...` subtree. Other authenticated users and anonymous
//    callers are denied at every operation.
//
// 2. Shape. Writes must contain exactly the three keys above, with the
//    correct types, and `markdown` must fit inside the 64 KiB cap that
//    the Pass 3 `FileMemoryStore` enforced client-side. Server-side
//    enforcement keeps a buggy or malicious client from poisoning the
//    document shape.
//
// Anything not matched below is denied by default.
service cloud.firestore {
  match /databases/{database}/documents {

    // Owner check shared across the memory collection.
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Shape check for a memory document payload. Used on both create
    // and update so the contract is symmetric.
    function isWellFormedMemory(data) {
      return data.keys().hasOnly(['markdown', 'updatedAt', 'schemaVersion'])
        && data.keys().hasAll(['markdown', 'updatedAt', 'schemaVersion'])
        && data.markdown is string
        && data.markdown.size() <= 65536
        && data.updatedAt is timestamp
        && data.schemaVersion is int;
    }

    match /users/{uid}/memories/{contactId} {
      // `read` covers both `get` and `list`. The owner is the only
      // caller that can scan their own memories collection.
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && isWellFormedMemory(request.resource.data);

      allow update: if isOwner(uid)
        && isWellFormedMemory(request.resource.data);

      allow delete: if isOwner(uid);
    }

    // Shape check for a connection document payload. Pass 4.5 (#066)
    // adds the connections collection at
    //   users/{uid}/connections/{contactId}
    //
    // Required fields are pinned by `hasAll` plus per-field type
    // checks. The Dart `Connection` model declares `email` and
    // `notes` as required non-nullable strings, so the rules treat
    // them the same way — empty strings are allowed (PRD §Q8) but
    // the keys must always be present. Only `isSample` and
    // `lastBondDriftAppliedAt` are genuinely optional, using the
    // "present-and-typed-or-absent" pattern.
    // The closed shape (`hasOnly`) keeps a buggy or malicious
    // client from poisoning the document with unknown fields.
    // `bondScore` is range-clamped 0..100 server-side mirroring the
    // client clamp in `applyAiUpdateResult`
    // (lib/src/state/app_state.dart).
    function isWellFormedConnection(data) {
      return data.keys().hasOnly([
          'id', 'name', 'email', 'category', 'avatar', 'bondScore',
          'nextStep', 'lastContact', 'notes', 'knownSince',
          'preferredChannels', 'schemaVersion', 'updatedAt',
          'isSample', 'lastBondDriftAppliedAt'
        ])
        && data.keys().hasAll([
          'id', 'name', 'email', 'category', 'avatar', 'bondScore',
          'nextStep', 'lastContact', 'notes', 'knownSince',
          'preferredChannels', 'schemaVersion', 'updatedAt'
        ])
        && data.id is string
        && data.name is string
        && data.email is string
        && data.category is string
        && data.avatar is string
        && data.bondScore is int
        && data.bondScore >= 0
        && data.bondScore <= 100
        && data.nextStep is string
        && data.lastContact is timestamp
        && data.notes is string
        && data.knownSince is timestamp
        && data.preferredChannels is list
        && data.schemaVersion is int
        && data.updatedAt is timestamp
        && (!('isSample' in data.keys()) || data.isSample is bool)
        && (!('lastBondDriftAppliedAt' in data.keys())
            || data.lastBondDriftAppliedAt is timestamp);
    }

    match /users/{uid}/connections/{contactId} {
      // `read` covers both `get` and `list`.
      allow read: if isOwner(uid);

      // S3 (review fix): `data.id` mirrors the document key. Pinning
      // them equal on every write prevents a client from writing
      // `{id: 'alice', ...}` to `connections/sarah` and surfacing a
      // mismatched Connection.id in the Dart adapter.
      allow create: if isOwner(uid)
        && isWellFormedConnection(request.resource.data)
        && request.resource.data.id == contactId;

      allow update: if isOwner(uid)
        && isWellFormedConnection(request.resource.data)
        && request.resource.data.id == contactId;

      allow delete: if isOwner(uid);
    }

    // Shape check for an interaction document payload. Pass 4.5
    // (#067) adds the interactions collection at
    //   users/{uid}/interactions/{interactionId}
    //
    // Required fields are pinned by `hasAll` plus per-field type
    // checks. The Dart `CrmInteraction` model declares `title` and
    // `note` as required non-nullable strings, so the rules treat
    // them the same way — empty strings are allowed (PRD §Q8) but
    // the keys must always be present. Genuinely optional fields
    // are `attachments` (default `const []`) and `source` (default
    // `InteractionSource.manual`), using the
    // "present-and-typed-or-absent" pattern.
    //
    // Enum string sets come from the Dart enums in
    // `lib/src/models/social_models.dart`:
    //   - InteractionType: interaction, personalDetail, preference,
    //     reminder, sharedActivity, relationshipNote
    //   - InteractionSource: manual, aiSuggested
    //
    // The closed shape (`hasOnly`) keeps a buggy or malicious
    // client from poisoning the document with unknown fields.
    function isWellFormedInteraction(data) {
      return data.keys().hasOnly([
          'id', 'contactId', 'type', 'title', 'note', 'date',
          'bondScoreDelta', 'schemaVersion', 'updatedAt',
          'attachments', 'attachmentUrls', 'source'
        ])
        && data.keys().hasAll([
          'id', 'contactId', 'type', 'title', 'note', 'date',
          'schemaVersion', 'updatedAt'
        ])
        && data.id is string
        && data.contactId is string
        && data.type is string
        && data.type in [
          'interaction', 'personalDetail', 'preference',
          'reminder', 'sharedActivity', 'relationshipNote'
        ]
        && data.title is string
        && data.note is string
        && data.date is timestamp
        && data.schemaVersion is int
        && data.updatedAt is timestamp
        && (!('attachments' in data.keys()) || data.attachments is list)
        && (!('attachmentUrls' in data.keys()) || data.attachmentUrls is list)
        && (!('bondScoreDelta' in data.keys()) || data.bondScoreDelta is int)
        && (!('source' in data.keys())
            || (data.source is string
                && data.source in ['manual', 'aiSuggested']));
    }

    match /users/{uid}/interactions/{interactionId} {
      // `read` covers both `get` and `list`.
      allow read: if isOwner(uid);

      // `data.id` must mirror the document key on every write.
      // Same invariant as connections (#066).
      allow create: if isOwner(uid)
        && isWellFormedInteraction(request.resource.data)
        && request.resource.data.id == interactionId;

      allow update: if isOwner(uid)
        && isWellFormedInteraction(request.resource.data)
        && request.resource.data.id == interactionId;

      allow delete: if isOwner(uid);
    }

    // Shape check for an event document payload. Pass 4.5 (#068)
    // adds the events collection at
    //   users/{uid}/events/{eventId}
    //
    // Required fields are pinned by `hasAll` plus per-field type
    // checks. The Dart `PlannerEvent` model declares `title`,
    // `category`, `note`, `eventType` as required non-nullable
    // strings, so the rules treat them the same way — empty strings
    // are allowed (PRD §Q8) but the keys must always be present.
    // Genuinely optional fields are `contactId`,
    // `startTimeMinutes`, `endTimeMinutes`, `recurrencePattern`,
    // using the "present-and-typed-or-absent" pattern.
    //
    // `eventType` is intentionally NOT validated against an enum
    // set per PRD §Q8. The eventTypes list is per-user data
    // (Pass 4.5 Q12) and bad client data is recoverable
    // client-side. Only the type is enforced.
    //
    // `recurrencePattern` IS validated against the
    // [RecurrencePattern] Dart enum string set since the values
    // are app-defined.
    //
    // The closed shape (`hasOnly`) keeps a buggy or malicious
    // client from poisoning the document with unknown fields.
    function isWellFormedEvent(data) {
      return data.keys().hasOnly([
          'id', 'title', 'category', 'date', 'note', 'eventType',
          'isAllDay', 'isRecurring', 'schemaVersion', 'updatedAt',
          'contactId', 'startTimeMinutes', 'endTimeMinutes',
          'recurrencePattern'
        ])
        && data.keys().hasAll([
          'id', 'title', 'category', 'date', 'note', 'eventType',
          'isAllDay', 'isRecurring', 'schemaVersion', 'updatedAt'
        ])
        && data.id is string
        && data.title is string
        && data.category is string
        && data.date is timestamp
        && data.note is string
        && data.eventType is string
        && data.isAllDay is bool
        && data.isRecurring is bool
        && data.schemaVersion is int
        && data.updatedAt is timestamp
        && (!('contactId' in data.keys()) || data.contactId is string)
        && (!('startTimeMinutes' in data.keys())
            || data.startTimeMinutes is int)
        && (!('endTimeMinutes' in data.keys())
            || data.endTimeMinutes is int)
        && (!('recurrencePattern' in data.keys())
            || (data.recurrencePattern is string
                && data.recurrencePattern in
                  ['daily', 'weekly', 'monthly', 'yearly']));
    }

    match /users/{uid}/events/{eventId} {
      // `read` covers both `get` and `list`.
      allow read: if isOwner(uid);

      // `data.id` must mirror the document key on every write.
      // Same invariant as connections (#066) and interactions
      // (#067).
      allow create: if isOwner(uid)
        && isWellFormedEvent(request.resource.data)
        && request.resource.data.id == eventId;

      allow update: if isOwner(uid)
        && isWellFormedEvent(request.resource.data)
        && request.resource.data.id == eventId;

      allow delete: if isOwner(uid);
    }

    // Per-user document. Pass 4.2 (#059) added the disk→Firestore
    // migration sentinel here at
    //   users/{uid}.migratedFromDiskAt: timestamp
    // Pass 4.5 (#069) extends the same shape with five seeder
    // sentinels marking which collections / user-doc fields have
    // been initialized on first authenticated launch:
    //   users/{uid}.connectionsSeededAt: timestamp
    //   users/{uid}.interactionsSeededAt: timestamp
    //   users/{uid}.eventsSeededAt: timestamp
    //   users/{uid}.categoriesSeededAt: timestamp
    //   users/{uid}.eventTypesSeededAt: timestamp
    // Plus two list-typed user-data fields (Pass 4.5 §Q12) seeded
    // at the same time as their corresponding sentinels:
    //   users/{uid}.categories: list<string>
    //   users/{uid}.eventTypes: list<string>
    // The owner is the only caller that can read or write their
    // own user doc.
    function isWellFormedUserDoc(data) {
      return data.keys().hasOnly([
          'migratedFromDiskAt',
          'connectionsSeededAt',
          'interactionsSeededAt',
          'eventsSeededAt',
          'categoriesSeededAt',
          'eventTypesSeededAt',
          'categories',
          'eventTypes',
          'notificationPreferences',
          'topicSuggestionsBackfillV1CompletedAt'
        ])
        && (!('migratedFromDiskAt' in data.keys())
            || data.migratedFromDiskAt is timestamp)
        && (!('topicSuggestionsBackfillV1CompletedAt' in data.keys())
            || data.topicSuggestionsBackfillV1CompletedAt is timestamp)
        && (!('connectionsSeededAt' in data.keys())
            || data.connectionsSeededAt is timestamp)
        && (!('interactionsSeededAt' in data.keys())
            || data.interactionsSeededAt is timestamp)
        && (!('eventsSeededAt' in data.keys())
            || data.eventsSeededAt is timestamp)
        && (!('categoriesSeededAt' in data.keys())
            || data.categoriesSeededAt is timestamp)
        && (!('eventTypesSeededAt' in data.keys())
            || data.eventTypesSeededAt is timestamp)
        && (!('categories' in data.keys()) || data.categories is list)
        && (!('eventTypes' in data.keys()) || data.eventTypes is list)
        && (!('notificationPreferences' in data.keys())
            || isWellFormedNotificationPreferences(
              data.notificationPreferences
            ));
    }

    function isWellFormedNotificationPreferences(data) {
      return data is map
        && data.keys().hasOnly([
          'enabled',
          'suggestedCheckIns',
          'plannerReminders',
          'birthdayReminders',
          'defaultReminderMinutes',
          'birthdayReminderMinutes',
          'quietHoursEnabled',
          'quietStartMinutes',
          'quietEndMinutes',
          'timeZone',
          'schemaVersion'
        ])
        && data.keys().hasAll([
          'enabled',
          'suggestedCheckIns',
          'plannerReminders',
          'birthdayReminders',
          'defaultReminderMinutes',
          'quietHoursEnabled',
          'quietStartMinutes',
          'quietEndMinutes',
          'timeZone',
          'schemaVersion'
        ])
        && data.enabled is bool
        && data.suggestedCheckIns is bool
        && data.plannerReminders is bool
        && data.birthdayReminders is bool
        && data.defaultReminderMinutes is int
        && data.defaultReminderMinutes >= 1
        && data.defaultReminderMinutes <= 525600
        && (!('birthdayReminderMinutes' in data.keys())
            || (data.birthdayReminderMinutes is int
                && data.birthdayReminderMinutes >= 0
                && data.birthdayReminderMinutes <= 525600))
        && data.quietHoursEnabled is bool
        && data.quietStartMinutes is int
        && data.quietStartMinutes >= 0
        && data.quietStartMinutes < 1440
        && data.quietEndMinutes is int
        && data.quietEndMinutes >= 0
        && data.quietEndMinutes < 1440
        && data.timeZone is string
        && data.timeZone.size() > 0
        && data.timeZone.size() <= 64
        && data.schemaVersion == 1;
    }

    function isWellFormedNotificationToken(data) {
      return data.keys().hasOnly([
          'token', 'platform', 'timeZone', 'updatedAt', 'schemaVersion'
        ])
        && data.keys().hasAll([
          'token', 'platform', 'timeZone', 'updatedAt', 'schemaVersion'
        ])
        && data.token is string
        && data.token.size() > 0
        && data.token.size() <= 4096
        && data.platform is string
        && data.platform in ['android', 'ios', 'macos']
        && data.timeZone is string
        && data.timeZone.size() > 0
        && data.timeZone.size() <= 64
        && data.updatedAt is timestamp
        && data.schemaVersion == 1;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && isWellFormedUserDoc(request.resource.data);
      allow delete: if false;
    }

    match /users/{uid}/notificationTokens/{tokenHash} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && isWellFormedNotificationToken(request.resource.data);
      allow delete: if isOwner(uid);
    }

    // Default deny — anything outside the explicit memory path is
    // refused. Future Pass 4.x work (user document sentinel, etc.)
    // will add narrowly scoped rules of its own.
  }
}
