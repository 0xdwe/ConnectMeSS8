rules_version = '2';

// Connect Me — per-contact memory rules.
//
// Memory documents live at:
//   users/{uid}/memories/{contactId}
//
// A memory document is a single Firestore document with three fields:
//   - markdown:      string, <= 64 KiB (65536 bytes)
//   - updatedAt:     timestamp
//   - schemaVersion: int
//
// Rules enforce two things in lock-step:
//
// 1. Ownership. Only the signed-in user whose UID matches the path can
//    read, list, create, update, or delete documents under their own
//    `users/{uid}/...` subtree. Other authenticated users and anonymous
//    callers are denied at every operation.
//
// 2. Shape. Writes must contain exactly the three keys above, with the
//    correct types, and `markdown` must fit inside the 64 KiB cap that
//    the Pass 3 `FileMemoryStore` enforced client-side. Server-side
//    enforcement keeps a buggy or malicious client from poisoning the
//    document shape.
//
// Anything not matched below is denied by default.
service cloud.firestore {
  match /databases/{database}/documents {

    // Owner check shared across the memory collection.
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Shape check for a memory document payload. Used on both create
    // and update so the contract is symmetric.
    function isWellFormedMemory(data) {
      return data.keys().hasOnly(['markdown', 'updatedAt', 'schemaVersion'])
        && data.keys().hasAll(['markdown', 'updatedAt', 'schemaVersion'])
        && data.markdown is string
        && data.markdown.size() <= 65536
        && data.updatedAt is timestamp
        && data.schemaVersion is int;
    }

    match /users/{uid}/memories/{contactId} {
      // `read` covers both `get` and `list`. The owner is the only
      // caller that can scan their own memories collection.
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && isWellFormedMemory(request.resource.data);

      allow update: if isOwner(uid)
        && isWellFormedMemory(request.resource.data);

      allow delete: if isOwner(uid);
    }

    // Shape check for a connection document payload. Pass 4.5 (#066)
    // adds the connections collection at
    //   users/{uid}/connections/{contactId}
    //
    // Required fields are pinned by `hasAll` plus per-field type
    // checks. The Dart `Connection` model declares `email` and
    // `notes` as required non-nullable strings, so the rules treat
    // them the same way — empty strings are allowed (PRD §Q8) but
    // the keys must always be present. Only `isSample` is genuinely
    // optional, using the "present-and-typed-or-absent" pattern.
    // The closed shape (`hasOnly`) keeps a buggy or malicious
    // client from poisoning the document with unknown fields.
    // `bondScore` is range-clamped 0..100 server-side mirroring the
    // client clamp in `applyAiUpdateResult`
    // (lib/src/state/app_state.dart).
    function isWellFormedConnection(data) {
      return data.keys().hasOnly([
          'id', 'name', 'email', 'category', 'avatar', 'bondScore',
          'nextStep', 'lastContact', 'notes', 'knownSince',
          'preferredChannels', 'schemaVersion', 'updatedAt',
          'isSample'
        ])
        && data.keys().hasAll([
          'id', 'name', 'email', 'category', 'avatar', 'bondScore',
          'nextStep', 'lastContact', 'notes', 'knownSince',
          'preferredChannels', 'schemaVersion', 'updatedAt'
        ])
        && data.id is string
        && data.name is string
        && data.email is string
        && data.category is string
        && data.avatar is string
        && data.bondScore is int
        && data.bondScore >= 0
        && data.bondScore <= 100
        && data.nextStep is string
        && data.lastContact is timestamp
        && data.notes is string
        && data.knownSince is timestamp
        && data.preferredChannels is list
        && data.schemaVersion is int
        && data.updatedAt is timestamp
        && (!('isSample' in data.keys()) || data.isSample is bool);
    }

    match /users/{uid}/connections/{contactId} {
      // `read` covers both `get` and `list`.
      allow read: if isOwner(uid);

      // S3 (review fix): `data.id` mirrors the document key. Pinning
      // them equal on every write prevents a client from writing
      // `{id: 'alice', ...}` to `connections/sarah` and surfacing a
      // mismatched Connection.id in the Dart adapter.
      allow create: if isOwner(uid)
        && isWellFormedConnection(request.resource.data)
        && request.resource.data.id == contactId;

      allow update: if isOwner(uid)
        && isWellFormedConnection(request.resource.data)
        && request.resource.data.id == contactId;

      allow delete: if isOwner(uid);
    }

    // Per-user document. Pass 4.2 (#059) adds the disk→Firestore
    // migration sentinel here at
    //   users/{uid}.migratedFromDiskAt: timestamp
    // The owner is the only caller that can read or write their
    // own user doc. The shape check pins the only field Pass 4.2
    // expects; later passes that add fields here update both this
    // rule and the JS rules tests.
    function isWellFormedUserDoc(data) {
      return data.keys().hasOnly(['migratedFromDiskAt'])
        && (!data.keys().hasAny(['migratedFromDiskAt'])
            || data.migratedFromDiskAt is timestamp);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && isWellFormedUserDoc(request.resource.data);
      allow delete: if false;
    }

    // Default deny — anything outside the explicit memory path is
    // refused. Future Pass 4.x work (user document sentinel, etc.)
    // will add narrowly scoped rules of its own.
  }
}
